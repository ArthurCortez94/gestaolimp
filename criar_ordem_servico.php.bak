<?php
session_start();
require_once 'config.php';

use Dompdf\Dompdf;
use Dompdf\Options;

$pdo->setAttribute(PDO::ATTR_ERRMODE, PDO::ERRMODE_EXCEPTION);

// Função para gerar número da ordem de serviço
function gerarNumeroOrdem(PDO $pdo): string {
    $stmt = $pdo->query("SELECT MAX(id) FROM ordens_servico");
    $ultimo_id = $stmt->fetchColumn() ?: 0;
    return 'OS-' . str_pad($ultimo_id + 1, 3, '0', STR_PAD_LEFT) . '/' . date('Y');
}

// Carregar dados do orçamento
$orcamento = [];
$ordem = [];
$orcamento_id = isset($_GET['orcamento_id']) ? (int)$_GET['orcamento_id'] : 0;
if ($orcamento_id > 0) {
    try {
        $stmt = $pdo->prepare("
            SELECT o.*, c.* 
            FROM orcamentos o 
            JOIN clientes c ON o.cliente_id = c.id 
            WHERE o.id = ?
        ");
        $stmt->execute([$orcamento_id]);
        $orcamento = $stmt->fetch(PDO::FETCH_ASSOC);

        if (!$orcamento) {
            die("Nenhum orçamento encontrado para o ID: $orcamento_id.");
        }

        $servicos = json_decode($orcamento['descricao_servico'], true) ?: [];
        $descricao_servico = '';
        foreach ($servicos as $servico) {
            $descricao_servico .= "- {$servico['nome']} (Qtd: {$servico['quantidade']}, Valor Unitário: R$ " . number_format($servico['valor_unitario'], 2, ',', '.') . ")\n";
        }

        // Carregar dados da ordem de serviço, se existir
        $stmt = $pdo->prepare("SELECT * FROM ordens_servico WHERE orcamento_id = ?");
        $stmt->execute([$orcamento_id]);
        $ordem = $stmt->fetch(PDO::FETCH_ASSOC);

    } catch (PDOException $e) {
        die("Erro ao carregar dados: " . $e->getMessage());
    }
} else {
    die("Nenhum orcamento_id fornecido na URL.");
}

// Carregar técnicos da tabela usuarios
$tecnicos = [];
try {
    $stmt = $pdo->query("SELECT id, nome FROM usuarios WHERE cargo = 'tecnico' AND ativo = 1 ORDER BY nome");
    $tecnicos = $stmt->fetchAll(PDO::FETCH_ASSOC);
} catch (PDOException $e) {
    die("Erro ao carregar técnicos: " . $e->getMessage());
}

// Processar o formulário
if ($_SERVER['REQUEST_METHOD'] === 'POST') {
    try {
        // Buscar o nome do técnico selecionado (apenas para o PDF)
        $tecnico_id = (int)$_POST['tecnico_id'];
        $stmt = $pdo->prepare("SELECT nome FROM usuarios WHERE id = ?");
        $stmt->execute([$tecnico_id]);
        $tecnico_nome = $stmt->fetchColumn();
        if (!$tecnico_nome) {
            throw new Exception("Técnico não encontrado.");
        }

        $dados = [
            'tipo_cliente' => $orcamento['tipo_cliente'],
            'nome' => $orcamento['nome'],
            'razao_social' => $orcamento['razao_social'] ?? null,
            'nome_fantasia' => $orcamento['nome_fantasia'] ?? null,
            'cnpj_cpf' => $orcamento['cnpj_cpf'],
            'endereco' => $orcamento['endereco'],
            'numero' => $orcamento['numero'],
            'complemento' => $orcamento['complemento'] ?? null,
            'bairro' => $orcamento['bairro'],
            'cidade' => $orcamento['cidade'],
            'uf' => $orcamento['uf'],
            'cep' => $orcamento['cep'],
            'telefone' => $orcamento['telefone'],
            'email' => $orcamento['email'] ?? null,
            'servicos' => $servicos,
            'tecnico_id' => $tecnico_id,
            'tecnico_nome' => $tecnico_nome,
            'data_servico' => $_POST['data_servico'],
            'hora_servico' => $_POST['hora_servico'],
            'previsao_conclusao' => $_POST['previsao_conclusao'],
            'observacoes' => $_POST['observacoes'] ?? null,
            'informacoes_extras' => $_POST['informacoes_extras'] ?? null,
            'data_emissao' => date('Y-m-d'),
            'status' => 'Agendado',
            'total' => $orcamento['total'],
            'forma_pagamento' => $orcamento['forma_pagamento']
        ];

        // Validações
        if (empty($tecnico_id)) {
            throw new Exception("Técnico responsável é obrigatório.");
        }
        if (!preg_match('/^\d{4}-\d{2}-\d{2}$/', $dados['data_servico'])) {
            throw new Exception("Data do serviço inválida.");
        }
        if (!preg_match('/^\d{2}:\d{2}$/', $dados['hora_servico'])) {
            throw new Exception("Hora do serviço inválida.");
        }

        // Validar o status para ordens_servico
        $valid_statuses = ['Aberta', 'Agendado', 'Em Andamento', 'Concluída', 'Cancelada'];
        if (!in_array($dados['status'], $valid_statuses)) {
            throw new Exception("Status inválido para ordens_servico: " . $dados['status']);
        }

        $cliente_id = $orcamento['cliente_id'];
        $numero_ordem = $ordem['numero_ordem'] ?? gerarNumeroOrdem($pdo);

        // Verificar se já existe uma ordem e atualizar ou inserir
        if ($ordem) {
            $stmt = $pdo->prepare("UPDATE orcamentos SET status = 'Agendado' WHERE id = ?");
            $stmt->execute([$orcamento_id]);

            $stmt = $pdo->prepare("UPDATE ordens_servico SET 
                tecnico_id = ?, data_servico = ?, hora_servico = ?, previsao_conclusao = ?, 
                status = ?, observacoes = ?, informacoes_extras = ?, total = ?
                WHERE id = ?");
            $stmt->execute([
                $dados['tecnico_id'], $dados['data_servico'], $dados['hora_servico'], $dados['previsao_conclusao'],
                $dados['status'], $dados['observacoes'], $dados['informacoes_extras'], $dados['total'], $ordem['id']
            ]);
        } else {
            $stmt = $pdo->prepare("UPDATE orcamentos SET status = 'Agendado' WHERE id = ?");
            $stmt->execute([$orcamento_id]);

            $stmt = $pdo->prepare("INSERT INTO ordens_servico (
                cliente_id, orcamento_id, tecnico_id, numero_ordem, data_emissao, data_servico, hora_servico, previsao_conclusao, 
                status, descricao_servicos, observacoes, informacoes_extras, total, caminho_pdf
            ) VALUES (?,?,?,?,?,?,?,?,?,?,?,?,?,?)");
            $caminho_pdf = null;
            $stmt->execute([
                $cliente_id, $orcamento_id, $dados['tecnico_id'], $numero_ordem, $dados['data_emissao'], $dados['data_servico'], $dados['hora_servico'],
                $dados['previsao_conclusao'], $dados['status'], json_encode($dados['servicos']),
                $dados['observacoes'], $dados['informacoes_extras'], $dados['total'], $caminho_pdf
            ]);
            $ordem_id = $pdo->lastInsertId();

            $stmt = $pdo->prepare("INSERT INTO agenda_servicos (ordem_id, data_agendamento, hora_agendamento) VALUES (?, ?, ?)");
            $stmt->execute([$ordem_id, $dados['data_servico'], $dados['hora_servico']]);
        }

        // Se o botão "Gerar PDF" foi clicado, gerar e exibir o PDF
        if (isset($_POST['gerar_pdf'])) {
            if (!file_exists('vendor/autoload.php')) {
                throw new Exception("Dompdf não está instalado. Execute 'composer require dompdf/dompdf' na raiz do projeto.");
            }
            require_once 'vendor/autoload.php';
            use Dompdf\Dompdf;
            use Dompdf\Options;

            // Criar um objeto Options
            $options = new Options();
            $options->setIsHtml5ParserEnabled(true);
            $options->setIsRemoteEnabled(true);

            $dompdf = new Dompdf($options);
            $html = gerarTemplatePDF($dados, $cliente_id, $numero_ordem);
            $dompdf->loadHtml($html);
            $dompdf->setPaper('A4', 'portrait');
            $dompdf->render();
            $dompdf->stream("Ordem_Servico_{$numero_ordem}.pdf", ['Attachment' => false]);
            exit();
        } else {
            header("Location: criar_ordem_servico.php?orcamento_id=$orcamento_id&success=Ordem salva com sucesso");
            exit();
        }

    } catch (Exception $e) {
        die("Erro ao processar ordem de serviço: " . $e->getMessage());
    }
}

function gerarTemplatePDF(array $dados, int $cliente_id, string $numero_ordem): string {
    $data_geracao = date('d/m/Y H:i');
    $data_emissao_formatada = date('d/m/Y', strtotime($dados['data_emissao']));
    $data_servico_formatada = date('d/m/Y', strtotime($dados['data_servico'])) . ' às ' . $dados['hora_servico'];
    $previsao_conclusao_formatada = date('d/m/Y', strtotime($dados['previsao_conclusao']));
    $total_formatado = "R$ " . number_format($dados['total'], 2, ',', '.');

    $servicos_html = '';
    foreach ($dados['servicos'] as $index => $servico) {
        $subtotal = ($servico['quantidade'] ?? 0) * ($servico['valor_unitario'] ?? 0);
        $bg_color = $index % 2 == 0 ? '#f9f9f9' : '#ffffff';
        $servicos_html .= "
            <tr style='background-color: {$bg_color};'>
                <td>" . ($index + 1) . "</td>
                <td>" . htmlspecialchars($servico['nome'] ?? '') . "</td>
                <td>" . htmlspecialchars($servico['quantidade'] ?? '') . "</td>
                <td style='text-align: right;'>R$ " . number_format($servico['valor_unitario'] ?? 0, 2, ',', '.') . "</td>
                <td style='text-align: right;'>R$ " . number_format($subtotal, 2, ',', '.') . "</td>
            </tr>";
    }

    return <<<HTML
    <!DOCTYPE html>
    <html>
    <head>
        <style>
            body { font-family: Arial, sans-serif; margin: 30px; }
            .header { border-bottom: 2px solid #333; padding-bottom: 20px; margin-bottom: 30px; }
            .info-box { margin-bottom: 30px; }
            table { width: 100%; border-collapse: collapse; margin-top: 20px; }
            th, td { padding: 10px; text-align: left; border-bottom: 1px solid #ddd; }
            .total-row { font-weight: bold; background-color: #f8f9fa; }
        </style>
    </head>
    <body>
        <div class="header">
            <h1>Ordem de Serviço #{$numero_ordem}</h1>
            <p>Data de emissão: {$data_geracao}</p>
        </div>

        <div class="info-box">
            <h3>Dados do Cliente</h3>
            <p>{$dados['nome']}<br>
            {$dados['endereco']}, {$dados['numero']} - {$dados['bairro']}<br>
            {$dados['cidade']}/{$dados['uf']} - CEP: {$dados['cep']}<br>
            Tel: {$dados['telefone']} | Email: {$dados['email']}</p>
        </div>

        <h3>Detalhes dos Serviços</h3>
        <table>
            <tr>
                <th>ITEM</th>
                <th>NOME</th>
                <th>QTD.</th>
                <th>VR. UNIT.</th>
                <th>SUBTOTAL</th>
            </tr>
            {$servicos_html}
            <tr class="total-row">
                <td colspan="4" style="text-align: right;">TOTAL:</td>
                <td style="text-align: right;">{$total_formatado}</td>
            </tr>
        </table>

        <div class="terms" style="margin-top: 40px;">
            <p>Técnico Responsável: {$dados['tecnico_nome']}</p>
            <p>Data e Hora do Serviço: {$data_servico_formatada}</p>
            <p>Previsão de Conclusão: {$previsao_conclusao_formatada}</p>
            <p>Status: {$dados['status']}</p>
            <p>Forma de Pagamento: {$dados['forma_pagamento']}</p>
            <p>Observações: {$dados['observacoes']}</p>
        </div>
    </body>
    </html>
HTML;
}
?>

